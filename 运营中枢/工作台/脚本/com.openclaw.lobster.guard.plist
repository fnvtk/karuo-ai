<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.lobster.guard</string>
  <key>Comment</key>
  <string>每 3 分钟检测龙虾网关 18789 + 飞书探针；异常则 doctor --fix（限流）+ kickstart</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/kr/.openclaw/lobster_guard.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/kr/.openclaw</string>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>180</integer>
  <key>StandardOutPath</key>
  <string>/Users/kr/.openclaw/lobster_guard_launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/kr/.openclaw/lobster_guard_launchd.err.log</string>
</dict>
</plist>
